{
  "pluginName": "秒回",
  "description": "客服快捷回复工具，秒级搜索与复制，支持变量填充与图片附件",
  "main": "index.html",
  "version": "1.1.0",
  "logo": "logo.png",
  "preload": "preload.js",
  "development": {
    "main": "http://localhost:5173"
  },
  "features": [
    {
      "code": "main",
      "explain": "打开快捷回复面板",
      "cmds": [
        "秒回",
        "快捷回复",
        "客服回复",
        "reply",
        {
          "type": "over",
          "label": "划词搜索回复"
        }
      ]
    },
    {
      "code": "admin",
      "explain": "管理回复内容与分类",
      "cmds": ["管理回复", "reply-admin"]
    }
  ]
}
